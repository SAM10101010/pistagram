rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    // Admin check: user must be authenticated and have an admin doc
    function isAdmin() {
      return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ══════════════════════════════════════════
    // ── Main App Collections ──
    // ══════════════════════════════════════════

    // ── Users ──
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isAuth();
      allow delete: if false;

      // ── Health History (subcollection) ──
      match /healthHistory/{historyId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update: if false;
        allow delete: if false;
      }
    }

    // ── Reels ──
    match /reels/{reelId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.creatorUid;
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Posts ──
    match /posts/{postId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.creatorUid;
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Stories ──
    match /stories/{storyId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.creatorUid;
      allow update: if isAuth();
      allow delete: if isAuth();

      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow delete: if isAuth();
      }
    }

    // ── Follows ──
    match /follows/{followId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // ── Likes ──
    match /likes/{likeId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAuth();
    }

    // ── Saves ──
    match /saves/{saveId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAuth();
    }

    // ── Saved Posts (bookmarks) ──
    match /savedPosts/{saveId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAuth();
    }

    // ── Comments ──
    match /comments/{commentId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() || isAdmin();
    }

    // ── Notifications ──
    match /notifications/{notifId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Transactions ──
    match /transactions/{txnId} {
      allow read: if isAuth();
      allow create: if isAuth() || isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Chats & Messages ──
    match /chats/{chatId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();

      match /messages/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update: if isAuth();
        allow delete: if isAuth();
      }
    }

    // ── Group Chats ──
    match /groupChats/{groupId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update: if isAuth();
        allow delete: if isAuth();
      }
    }

    // ── Group Invitations ──
    match /groupInvitations/{inviteId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Rewards ──
    match /rewards/{rewardId} {
      allow read: if isAuth();
      allow create: if isAuth() || isAdmin();
      allow update: if isAuth() || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Redemptions ──
    match /redemptions/{redemptionId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
    }

    // ── Reports ──
    match /reports/{reportId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() || isAdmin();
    }

    // ── Blocks ──
    match /blocks/{blockId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAuth();
    }

    // ── Warnings ──
    match /warnings/{warningId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Appeals ──
    match /appeals/{appealId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Fraud Flags ──
    match /fraud_flags/{flagId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() || isAdmin();
    }

    // ══════════════════════════════════════════
    // ── Gamification Collections ──
    // ══════════════════════════════════════════

    // ── Reel Engagements ──
    match /reelEngagements/{engagementId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Reel Ratings ──
    match /reelRatings/{ratingId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Series ──
    match /series/{seriesId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.creatorUid;
      allow update: if isAuth() && request.auth.uid == resource.data.creatorUid;
      allow delete: if false;
    }

    // ── Series Progress ──
    match /seriesProgress/{progressId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Leaderboard Weekly ──
    match /leaderboardWeekly/{uid} {
      allow read: if isAuth();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ── Leaderboard Monthly ──
    match /leaderboardMonthly/{uid} {
      allow read: if isAuth();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ── User Achievements ──
    match /userAchievements/{achievementId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ── Campaigns ──
    match /campaigns/{campaignId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Campaign Progress ──
    match /campaignProgress/{progressId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Boosted Reels ──
    match /boostedReels/{reelId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Predictions ──
    match /predictions/{predictionId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Mystery Box Results ──
    match /mysteryBoxResults/{resultId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ── Story Reactions ──
    match /storyReactions/{reactionId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // ── Point Transfers ──
    match /pointTransfers/{transferId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ── Vault Reels ──
    match /vaultReels/{vaultId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAuth();
      allow update: if false;
    }

    // ── App Settings (admin signup toggle, etc.) ──
    match /appSettings/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Collab Invites ──
    match /collabInvites/{inviteId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Reel Watch Rewards (per-user dedup) ──
    match /reelWatchRewards/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ══════════════════════════════════════════
    // ── Admin App Collections ──
    // ══════════════════════════════════════════

    // ── Admins (admin user profiles) ──
    match /admins/{adminId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Admin Activity Logs ──
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ── Support Tickets ──
    match /supportTickets/{ticketId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() || isAdmin();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update: if false;
        allow delete: if false;
      }

      match /internalNotes/{noteId} {
        allow read: if isAdmin();
        allow create: if isAdmin();
        allow update: if false;
        allow delete: if false;
      }
    }

    // ── Challenges ──
    match /challenges/{challengeId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Moderation Queue ──
    match /moderationQueue/{itemId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Manipulation Alerts ──
    match /manipulationAlerts/{alertId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Report Votes ──
    match /reportVotes/{voteId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ── Ranking Audit Logs ──
    match /rankingAuditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }
  }
}